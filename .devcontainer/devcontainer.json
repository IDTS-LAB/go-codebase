{
    "name": "go-codebase",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-from-docker:2": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "forwardPorts": [5432],
    "portsAttributes": {
        "5432": {
            "label": "PostgreSQL"
        }
    },
    "remoteEnv": {
        "DB_HOST": "localhost",
        "DB_PORT": "5432",
        "DB_USER": "postgres",
        "DB_PASSWORD": "postgres",
        "DB_NAME": "codebase_testing",
        "DB_SSLMODE": "disable"
    },
    "postCreateCommand": "go mod download"
}
